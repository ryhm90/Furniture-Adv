<?xml version="1.0" encoding="UTF-8"?>
<configuration>
  <system.webServer>
    <rewrite>
      <rules>
        <rule name="ReverseProxyToFurni" stopProcessing="true">
          <match url="(.*)" />
          <action type="Rewrite" url="http://localhost:3000/{R:1}" />
        </rule>
                <rule name="RedirectHTTPToHTTPS" stopProcessing="true">
                    <match url="(.*)" />
                    <action type="Redirect" url="https://furni.sandcript.com/{R:1}" />
                </rule>
      </rules>
    </rewrite>
  </system.webServer>
</configuration>
